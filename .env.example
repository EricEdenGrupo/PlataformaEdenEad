# Frontend (Vite) — Settings → API no Dashboard do projeto Supabase
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Use UMA das duas (a publishable é o formato novo do painel):
# VITE_SUPABASE_ANON_KEY=eyJhbGci...
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Assets carregados via CloudFront CDN fixo:
# https://cdn.edengrupo.com.br

# Newsletter (Mautic + Captcha)
# URL de action do formulário Mautic (POST)
VITE_MAUTIC_FORM_ACTION=
# Site key do Cloudflare Turnstile para captcha
VITE_TURNSTILE_SITE_KEY=
