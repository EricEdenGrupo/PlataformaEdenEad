# Frontend (Vite) — Settings → API no Dashboard do projeto Supabase
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Use UMA das duas (a publishable é o formato novo do painel):
# VITE_SUPABASE_ANON_KEY=eyJhbGci...
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Assets em S3 (thumb, avatar, banners, materiais, etc)
VITE_S3_BUCKET_BASE_URL=https://your-bucket.s3.your-region.amazonaws.com
